# Backend Environment Variables
# Copy this file to .env and fill in your values.

# Port the Express server listens on (default: 5000)
PORT=5000

# Absolute path to the SQLite database file (for production deployments only)
# DATABASE_PATH=/opt/dpmc-database/dpmc.db

# Allowed CORS origin for production (optional – add your frontend domain)
# ALLOWED_ORIGIN=https://your-frontend.vercel.app
